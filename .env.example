# Supabase — project "tablefront-reservations": Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
# Sender for transactional email. Until your domain is verified in Resend,
# use "TableFront <onboarding@resend.dev>".
EMAIL_FROM=TableFront <onboarding@resend.dev>

# Shared secret for /admin (create restaurants). Pick a long random string.
ADMIN_SECRET=

# Public URL of the deployed app, used in embed snippets.
NEXT_PUBLIC_APP_URL=https://app.tablesfront.com
